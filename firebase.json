{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      "server/**",
      "functions/**",
      "node_modules/**",
      ".git/**",
      ".claude/**",
      "docs/**",
      "deploy.sh"
    ],
    "rewrites": [
      { "source": "/api/audience-check", "function": "api" },
      { "source": "/health", "function": "api" }
    ]
  },
  "functions": {
    "source": "functions",
    "runtime": "nodejs20"
  }
}
